---
import { Image } from "astro:assets";
import base from "../assets/record/base.png";
import base2 from "../assets/record/base2.png";
import disc from "../assets/record/disc.png";

// Настрой центр вращения
const centerX = "50.0%"; 
const centerY = "50.0%";

// Настрой положение подложки base - это пластинка
const baseX = "0px";
const baseY = "0px";

// Настрой положение грамофона
const gramophoneX = "200px"; 
---
<div class="relative w-64 h-64 mx-auto lg:mx-0" style={`transform: translateX(${gramophoneX});`}>
  <Image 
    src={base} 
    alt="Gramophone Base" 
    class="absolute inset-0 z-10 w-full h-full object-contain" 
    style={`transform: translate(${baseX}, ${baseY});`}
  />  
  <div class="absolute inset-0 z-20 flex items-center justify-center pointer-events-none">
    <div class="music-disc-container w-[67%] aspect-square relative">
      <Image 
        src={disc} 
        alt="Gramophone Disc" 
        class="w-full h-full object-contain block"
        style="aspect-ratio: 1/1;"
      />
    </div>
  </div>
  </div>
  <Image 
    src={base2} 
    alt="Gramophone Top" 
    class="absolute inset-0 z-30 w-full h-full object-contain pointer-events-none" 
    style={`transform: translateX(${gramophoneX});`}
  />
</div>
<script>  function updateDiscAnimation() {
    const isPlaying = localStorage.getItem('music-playing') === 'true';
    const discContainer = document.querySelector('.music-disc-container') as HTMLElement;
    if (discContainer) {
      discContainer.style.animationPlayState = isPlaying ? 'running' : 'paused';
    }
  }

  updateDiscAnimation();
  document.addEventListener('DOMContentLoaded', updateDiscAnimation); 
  document.addEventListener('astro:page-load', updateDiscAnimation);
  updateDiscAnimation();

  window.addEventListener('storage', (e) => {
    if (e.key === 'music-playing') updateDiscAnimation();
  });

  window.addEventListener('music-state-changed', updateDiscAnimation);
</script>

<style define:vars={{ centerX, centerY }}>
  .music-disc-container {
    display: block;
    will-change: transform;
    animation: gramophone-spin 3s linear infinite;
    animation-play-state: paused;
    transform-origin: var(--centerX) var(--centerY);
  }

  .music-disc-container img {
    display: block;
    margin: auto;
  }

  @keyframes gramophone-spin {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }
</style>
