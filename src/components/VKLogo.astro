---
import type { HTMLAttributes } from "astro/types";

type Props = HTMLAttributes<"svg">;

const { class: className, ...props } = Astro.props;
---

<a
  href="https://vk.com/thatoneromus"
  target="_blank"
  rel="noopener noreferrer"
  class="p-2 transition-transform duration-400 ease-in-out hover:scale-135 lg:p-4"
>  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    class:list={[{ className }, "text-accent size-5"]}
    fill="currentColor"
    aria-hidden="true"
    {...props}
  >
    <title>VK</title>
    <path d="M13.162 18.994c-6.098 0-9.57-4.172-9.714-11.109h3.05c.1 5.089 2.348 7.245 4.13 7.693V7.885h2.87v4.391c1.756-.188 3.588-2.17 4.21-4.391h2.87a8.722 8.722 0 0 1-3.858 5.493 8.925 8.925 0 0 1 4.535 5.616h-3.135a5.41 5.41 0 0 0-4.622-3.637v3.637h-3.05z"/>  </svg>
</a>
